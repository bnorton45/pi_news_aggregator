# direnv config (committed; contains NO secrets). Run `direnv allow` once.
# Auto-loads the gitignored `.env` into the shell whenever you cd into the project,
# so GH_TOKEN etc. are present for git/gh/scripts without re-exporting each session.
#
# No direnv? Use the dependency-free fallback instead:  source scripts/dev-env.sh
dotenv_if_exists .env
