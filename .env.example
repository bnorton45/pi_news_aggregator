# Local dev secrets — COPY to `.env` and fill in. NEVER commit `.env` (gitignored).
#
# This file (.env.example) is committed and must contain NO real secrets — only
# placeholders. The real `.env` lives only on your machine. Production secrets do
# NOT come from here: the Anthropic key and GHCR pull token are SOPS-encrypted in
# deploy/secrets/ and only exist in-cluster (PLAN §3.5). `.env` is dev convenience.

# ── GitHub (for `git push` / `gh` from this project; NOT consumed by the app) ──
# PAT with `repo` + `workflow` scope. Picked up by git/gh via direnv or sourcing.
GH_TOKEN=

# ── Local data-path overrides (compose defaults to app/app/news if unset) ─────
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
# POSTGRES_DB=news
# NATS_URL=nats://localhost:4222

# ── Future (zone-process only; in cluster these come from SOPS, not .env) ──────
# ANTHROPIC_API_KEY=
# GHCR_PULL_TOKEN=
